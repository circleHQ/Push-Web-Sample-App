# Copy this file to `.env.local` and fill in your Circle API key.
# Vite reads this at build time and embeds the value in the bundle, so only
# use values that are safe to ship to a browser.
#
# The Firebase config and VAPID key are built into the SDK itself by Circle —
# you do not need to provide them.

# Your Circle publishable API key.
VITE_CIRCLE_API_KEY=
